APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000

# Docker network "infra" — use container_name from /opt/infra (cross-compose DNS)
DATABASE_URL=postgresql+psycopg://mytripspots:PASSWORD@infra-postgres:5432/mytripspots

CLERK_JWKS_URL=https://YOUR-CLERK-DOMAIN/.well-known/jwks.json
CLERK_ISSUER=https://YOUR-CLERK-DOMAIN

# Comma-separated frontend origin(s) — no path segment in origins
CORS_ALLOWED_ORIGINS=https://spotstogo.online,https://www.spotstogo.online

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT_URL=
UPLOAD_MAX_MB=4
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
