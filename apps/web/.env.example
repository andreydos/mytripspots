# Dev server port (must match `next dev -p` in package.json if you change it)
PORT=3001

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_API_GRAPHQL_URL=http://localhost:8000/graphql
# Optional: register the PWA service worker during `next dev` (default off; dev chunk URLs break offline cache).
# NEXT_PUBLIC_ENABLE_SW_IN_DEV=true
