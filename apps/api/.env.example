APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Supabase: Project Settings → Database → copy URI (pooler or direct). Use postgresql+psycopg://... for this API; add ?sslmode=require if the client needs it.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/postgres
# Local-only: postgresql+psycopg://postgres:postgres@localhost:5432/mytripspots
CLERK_JWKS_URL=https://YOUR-CLERK-DOMAIN/.well-known/jwks.json
CLERK_ISSUER=https://YOUR-CLERK-DOMAIN
# Comma-separated browser origins. On Render/production, set APP_ENV=production and list your frontend origin(s) here (e.g. https://your-app.vercel.app). Locally, optional (defaults to common Next.js localhost URLs; any localhost port still allowed when APP_ENV is development).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_PUBLIC_BASE_URL=
R2_ENDPOINT_URL=
UPLOAD_MAX_MB=4
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
