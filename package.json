{
  "name": "mytripspots",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "test": "pnpm --filter web test && pnpm test:api",
    "test:api": "cd apps/api && python -m pytest",
    "test:web": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "format": "pnpm --filter web format",
    "schema:export": "python apps/api/scripts/export_graphql_schema.py",
    "codegen": "pnpm --filter web codegen",
    "codegen:all": "pnpm schema:export && pnpm --filter web codegen"
  }
}
